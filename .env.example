# === KILO PROVIDER (path: /kilo/v1) ===
KILO_ENDPOINT=https://api.kilo.ai/api/gateway
KILO_FORMAT=openai
KILO_MODELS=deepseek/deepseek-v4-flash
KILO_API_KEYS_1=your-first-kilo-key
KILO_API_KEYS_2=your-second-kilo-key

# === OPENROUTER PROVIDER (path: /openrouter/v1) ===
# OPENROUTER_ENDPOINT=https://openrouter.ai/api/v1
# OPENROUTER_FORMAT=openai
# OPENROUTER_MODELS=google/gemini-2.0-flash-001,anthropic/claude-3.5-sonnet
# OPENROUTER_API_KEYS_1=your-first-openrouter-key
# OPENROUTER_API_KEYS_2=your-second-openrouter-key

# === GLOBAL ===
PROXY_AUTH_KEY=your-proxy-auth-key
PORT=8888
